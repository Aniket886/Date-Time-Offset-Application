#
# Copy this file to `.env` (which is gitignored) and fill in values.
#

# Django
DJANGO_SECRET_KEY=change-me
DJANGO_DEBUG=1
DJANGO_ALLOWED_HOSTS=127.0.0.1,localhost

# Optional: World Time API base URL used by offset_app
TIME_API_BASE_URL=https://gettimeapi.dev

# Chatbot provider: local | openai | groq
CHATBOT_PROVIDER=local

# OpenAI (only if CHATBOT_PROVIDER=openai)
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_BASE_URL=https://api.openai.com

# Groq (only if CHATBOT_PROVIDER=groq)
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant
GROQ_BASE_URL=https://api.groq.com/openai

